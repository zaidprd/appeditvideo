# secrets
.env
# OAuth tokens for yt_upload / yt_stats (client_secret.json, token.json, token-analytics.json)
.youtube/

# python
__pycache__/
*.pyc
venv/
.venv/

# node / remotion build output
node_modules/
remotion/out/
# generated by `npm run gen` (do not commit — regenerated from src/shots/)
remotion/src/registry.gen.tsx
remotion/src/shots.manifest.json

# ── RAW FOOTAGE & MASTER CUTS ──────────────────────────────────────────────
# Camera files and their master exports NEVER go to GitHub. The repo carries the
# reproducible pipeline (cuts.json, transcripts, plans, shots), not the footage.
videos/*/*.MP4
videos/*/*.mp4
videos/*/*.MOV
videos/*/*.mov
videos/*/reference/

# heavy / regenerable per-video artifacts (rebuilt by the pipeline)
videos/*/work/audio/
videos/*/work/render/
videos/*/work/editor/*.mp4
videos/*/work/editor/*.png
videos/*/output/
*.wav
*.aac

# rendered thumbnails show the presenter's face — keep the .txt/.json recipes, drop the images
videos/*/packaging/thumbs/*.png
videos/*/packaging/thumbs/*.jpg
videos/*/packaging/thumbs/*.jpeg

# personal face-reference kit — you supply your own (see media/library/faces/README.md)
media/library/faces/*.jpg
media/library/faces/*.jpeg
media/library/faces/*.png
media/library/faces/*.webp

# NOTE: the SFX/music library clips (media/library/sfx/clips, media/library/music/clips)
# ARE committed — so there is intentionally NO blanket *.mp3 rule here.

# editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
