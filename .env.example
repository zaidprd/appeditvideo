# Copy to .env (repo root) and fill in what you use. Never commit .env.
# The cut → clean → TSX → SFX core needs AssemblyAI + ElevenLabs; Gemini is only for thumbnails.
# yt_upload / yt_stats use OAuth, not a key here (see tools/yt_upload_SETUP.md and CLAUDE.md).

# AssemblyAI — transcription for the cut pipeline (tools/transcribe.py). Required for /clean-cut.
# https://assemblyai.com
ASSEMBLYAI_API_KEY=

# ElevenLabs — voice isolation (tools/clean_voice.py --method eleven), SFX generation
# (tools/gen_sfx.py), and music beds (tools/gen_music.py). Needed for /clean-audio + /suggest-sfx.
# /clean-audio's local RNNoise method needs no key if you would rather skip this one.
# https://elevenlabs.io
ELEVENLABS_API_KEY=

# Google Gemini — thumbnail generation with Nano Banana Pro (tools/gen_thumbnail.py, /packaging).
# Only needed if you render thumbnails.
# https://ai.google.dev
GEMINI_API_KEY=
